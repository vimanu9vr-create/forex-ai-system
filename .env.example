# Copy to app/.env and fill in your keys:   cp .env.example app/.env
# NEVER commit the real app/.env (it is gitignored).

# ── Market data ───────────────────────────────────────────
POLYGON_API_KEY=your_polygon_key          # primary feed — real forex tick-volume
TWELVEDATA_API_KEY=your_twelvedata_key    # fallback feed + deep history for backtests
FINNHUB_API_KEY=your_finnhub_key          # macro: economic calendar + market news

# ── CrewAI desk analyst (uses OpenAI) ─────────────────────
OPENAI_API_KEY=your_openai_key

# ── Telegram alerts ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Strategy (the cost + out-of-sample validated edge) ────
STRATEGY_PAIRS=GBPUSD,EURUSD
STRATEGY_TIMEFRAME=1day
SCAN_INTERVAL_SECONDS=3600
MIN_RISK_REWARD=3.0

# ── Auth / DB ─────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me
DATABASE_URL=sqlite:///./forex_ai.db

# ── Optional: OANDA (paper order prep only; NOT used in the live loop) ──
# OANDA_API_KEY=
# OANDA_ACCOUNT_ID=
# OANDA_ENVIRONMENT=practice
# OANDA_LIVE_TRADING=false
